# ============================================================
# wayback-cdx-dump configuration
# Copy to .env and fill in real values. NEVER commit .env
# ============================================================

# Proxy mode: auto | dc | isp | off
PROXY_MODE=auto

# --- Datacenter proxy (Oxylabs) ---
OXY_DC_USER=
OXY_DC_PASS=
OXY_DC_HOST=dc.oxylabs.io
OXY_DC_PORTS=8001,8002,8003,8004,8005,8006,8007,8008,8009,8010

# --- ISP proxy (Oxylabs) ---
OXY_ISP_USER=
OXY_ISP_PASS=
OXY_ISP_HOST=isp.oxylabs.io
OXY_ISP_PORTS=8001

# --- Rate control ---
CDX_MAX_RPS=2
CDX_MAX_CONCURRENCY=3

# --- Timeouts (seconds) ---
CDX_CONNECT_TIMEOUT=10
CDX_READ_TIMEOUT=60

# --- Retry ---
CDX_MAX_RETRIES=4
CDX_BACKOFF_BASE=1.0
CDX_BACKOFF_MAX=60.0
CDX_JITTER_MAX=1.0

# --- Circuit breaker ---
CDX_BREAKER_THRESHOLD=3
CDX_BREAKER_COOLDOWN=30

# --- Auto-escalation ---
CDX_ESC_ERROR_RATE=0.30
CDX_ESC_POOL_BROKEN=0.50
CDX_ESC_COOLDOWN=300

# --- User agent ---
CDX_USER_AGENT=wayback-cdx-dump/2.0
